# Copy this file to .env and fill in real values. Never commit .env.

# === Anthropic ===
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# === Naver Search Open API ===
# https://developers.naver.com/apps/
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# === SMTP (Gmail recommended for MVP) ===
# Use an App Password, NOT your real account password.
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Comma-separated list of recipient emails for the newsletter.
NEWSLETTER_RECIPIENTS=

# === Database ===
DB_URL=sqlite:///data/newsletter.db

# === Runtime ===
# json | console
LOG_FORMAT=console
LOG_LEVEL=INFO
ENV=development
