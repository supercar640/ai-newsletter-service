# Copy this file to .env and fill in real values. Never commit .env.

# === LLM Provider ===
# Which provider the pipeline uses for all LLM calls: anthropic | gemini
LLM_PROVIDER=gemini
# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Google Gemini — https://aistudio.google.com/
GEMINI_API_KEY=

# === Voyage AI (embeddings, Phase 2) ===
# Leave empty to disable semantic clustering — the pipeline falls back to
# lexical Jaccard. https://www.voyageai.com/
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3-lite

# === Notion archive (Phase 2) ===
# Create an internal integration at https://www.notion.so/my-integrations,
# share your archive database with it, and paste the integration token here.
# NOTION_DATABASE_ID is the 32-char id (with or without dashes) in the
# database URL: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_API_VERSION=2022-06-28

# === Naver Search Open API ===
# https://developers.naver.com/apps/
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# === YouTube Data API v3 ===
# Required for YOUTUBE_RSS enrichment and YOUTUBE_SEARCH collection.
# Get one at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
# Set to 0 to skip the Data API call (faster, but raw_content stays empty).
YOUTUBE_FETCH_METADATA=1

# === YouTube search (YOUTUBE_SEARCH source type) ===
# Top N videos to keep per search keyword (sorted by view count).
YOUTUBE_SEARCH_TOP_N=3
YOUTUBE_SEARCH_REGION=KR

# === Speech-to-text via faster-whisper ===
# Set to 0 to skip audio download + transcription (you only get title/description).
YOUTUBE_STT_ENABLED=1
# Model size: tiny / base / small / medium / large-v3
WHISPER_MODEL=small
# int8 / int8_float16 / float16 / float32 — int8 is fastest on CPU.
WHISPER_COMPUTE_TYPE=int8
# cpu / cuda
WHISPER_DEVICE=cpu
# "" = auto-detect, "ko" / "en" / "ja" / etc to force.
WHISPER_LANGUAGE=

# === Output ===
# Per-run artifacts (audio files, transcripts, scraped HTML) are written under
# DATA_DIR/runs/<timestamp>/<source-type>/<source-id>/.
DATA_DIR=data

# === SMTP (Gmail recommended for MVP) ===
# Use an App Password, NOT your real account password.
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Comma-separated list of recipient emails for the newsletter.
NEWSLETTER_RECIPIENTS=

# Slack distribution (Phase 2) — Incoming Webhook URL. Empty = Slack disabled.
SLACK_WEBHOOK_URL=

# 회사 관심사 RAG — 사내 문서(.md/.txt) 디렉터리. 비워두면 기능 비활성.
COMPANY_CONTEXT_DIR=docs/company

# === Database ===
DB_URL=sqlite:///data/newsletter.db

# === Runtime ===
# json | console
LOG_FORMAT=console
LOG_LEVEL=INFO
ENV=development
